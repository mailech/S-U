{
  "name": "scrape-upload",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone uploader for NICRA / Natural-Farming / Agri-Drone / Seed-Hub scrapes. Superadmin-side, multi-KVK: each row resolves to its own KVK. Preview -> edit -> push to DB.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "postinstall": "prisma generate",
    "validate": "node scripts/validate-mappings.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "pg": "^8.17.1"
  },
  "devDependencies": {
    "prisma": "^7.2.0"
  }
}
